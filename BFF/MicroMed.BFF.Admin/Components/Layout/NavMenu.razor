@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.Buttons

@rendermode InteractiveServer

@inject NavigationManager Navigation

<div class="control-container">
    <SfAppBar ColorMode="AppBarColor.Primary">
        <SfButton CssClass="e-inherit" IconCss="e-icons e-menu"></SfButton>
        <span class="regular">MicroMed Admin Portal</span>
        <SfButton CssClass="e-inherit" Content="Clinics" OnClick="@(() => Navigation.NavigateTo("clinics"))" />
        <SfButton CssClass="e-inherit" Content="Equipment" />
        <SfButton CssClass="e-inherit" Content="Doctors" />
        <SfButton CssClass="e-inherit" Content="Schedule" />
    </SfAppBar>
</div>

<style>
    .control-container .e-btn.e-inherit {
        margin: 0 3px;
    }

    .control-container .e-appbar {
        flex-flow: row wrap;
        flex-wrap: wrap;
        height: auto;
        gap: 8px;
    }
</style>